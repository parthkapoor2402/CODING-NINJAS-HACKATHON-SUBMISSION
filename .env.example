# CivicResolve — environment variables (copy to .env)

# Core
VITE_APP_NAME=CivicResolve
VITE_USE_MOCKS=true

# Backend adapter: mock | supabase | firebase
VITE_BACKEND_PROVIDER=mock

# AI — client routes through secure gateway (no browser API keys)
VITE_AI_PROVIDER=mock
VITE_AI_GATEWAY_ENABLED=true
# Optional override for deployed API origin (defaults to same origin)
# VITE_AGENT_API_BASE_URL=

# Server-only AI secrets (Vercel project env / local shell — NEVER prefix with VITE_)
# AI_PROVIDER=mock
# AI_PROVIDER=grok
# GROK_API_KEY=your_grok_api_key_here
# GROK_API_URL=https://api.x.ai/v1
# AI_GATEWAY_RATE_LIMIT_PER_MIN=30

# Deprecated — do not set client Grok keys (removed from browser bundle)
# VITE_GROK_API_KEY=

# Maps adapter: mock | mapbox | google
VITE_MAPS_PROVIDER=mock
# VITE_MAPBOX_TOKEN=your_mapbox_token_here
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Supabase (Phase 2+)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Firebase (Phase 2+)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=

# Media limits
VITE_MAX_IMAGE_MB=8
VITE_MAX_VIDEO_MB=25
VITE_MAX_VIDEO_SEC=30

# Demo / dev
# true = gallery upload only (predictable judge demos on desktop)
# false = live camera/video when device supports it (real phone demos)
VITE_FORCE_GALLERY_ONLY=false
